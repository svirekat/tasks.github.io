const double e = exp(1);
const double pi = 3.14159265359;

const int exampleNum = 2;

double a, b;
double Alpha, Beta;

const string file = "results2.csv";
string exact_sol;

double p(double x) {
	if (exampleNum == 1)
		return 0;
	else if (exampleNum == 2)
		return 0;
	else if (exampleNum == 3)
		return 0;
	else if (exampleNum == 4)
		return -2;
}

double q(double x) {
	if (exampleNum == 1)
		return -1;
	else if (exampleNum == 2)
		return 0;
	else if (exampleNum == 3)
		return 1;
	else if (exampleNum == 4)
		return 1;
}

double f(double x) {
	if (exampleNum == 1)
		return 2 * x;
	else if (exampleNum == 2)
		return -1;
	else if (exampleNum == 3)
		return 1;
	else if (exampleNum == 4)
		return cos(x);
}

// краевые условия
void initializeConditions() {
	if (exampleNum == 1) {
		a = 0;
		b = 1;
		Alpha = 0;
		Beta = e + 1/e - 2;
	}
	else if (exampleNum == 2) {
		a = 0;
		b = 1;
		Alpha = 1;
		Beta = 0;
	}
	else if (exampleNum == 3) {
		a = 0;
		b = pi;
		Alpha = 2;
		Beta = -1;
	}
	else if (exampleNum == 4) {
		a = -3*pi;
		b = 0;
		Alpha = exp(-3*pi);
		Beta = 0.5;
	}
}

// строка для вывода точного решения
void initializeExactSolString() {
	if (exampleNum == 1)
		exact_sol = "y = exp(x) - exp(-x) - 2x";
	else if (exampleNum == 2)
		exact_sol = "y = -0.5*x^2 + x + 1";
	else if (exampleNum == 3)
		exact_sol = "y = sin(x) + cos(x) + 1";
	else if (exampleNum == 4)
		exact_sol = "y = exp(x) - sin(x)/2";
}

// функция точного решения y
double exactSolution(double x) {
	if (exampleNum == 1)
		return exp(x) - exp(-x) - 2 * x;
	else if (exampleNum == 2)
		return -0.5 * (x*x) + x + 1;
	else if (exampleNum == 3)
		return sin(x) + cos(x) + 1;
	else if (exampleNum == 4)
		return exp(x) - sin(x) * 0.5;
}

// строка для вывода задачи
string problem() {
	if (exampleNum == 1)
		return "y'' - y = 2x\ny(0) = 0; y'(1) = e + 1/e - 2";
	else if (exampleNum == 2)
		return "y'' = -1\ny(0) = 1; y'(1) = 0";
	else if (exampleNum == 3)
		return "y'' + y = 1\ny(0) = 2; y'(pi) = -1";
	else if (exampleNum == 4)
		return "y'' - 2y' + y = cos(x)\ny(-3pi) = exp(-3pi); y'(0) = 0.5";
}

void metodProgonki(vector<double>& x, vector<double>& y, int N, double h) {
	double A, B, C, F;
	vector<double> alpha(N);
	vector<double> beta(N+1);

	// прямой ход:
	alpha[0] = 0;
	beta[0] = Alpha;
	for (int i = 1; i <= N-1; i++) {
		A = 1 - 0.5 * h * p(x[i]);
		B = -2 + h * h * q(x[i]);
		C = 1 + 0.5 * h * p(x[i]);
		F = f(x[i]) * h * h;

		double znamenatel = A * alpha[i - 1] + B;
		alpha[i] = -C / znamenatel;
		beta[i] = (F - A * beta[i - 1]) / znamenatel;
	}
	B = -2 + h * h * q(x[N]);
	C = 1 + 0.5 * h * p(x[N]);
	F = f(x[N]) * h * h;
	beta[N] = (F - 2 * h * Beta * C) / (2 * alpha[N - 1] + B);

	// обратный ход:
	//y[N] = beta[N];
	y[N] = (beta[N - 1] + h * Beta) / (1 - alpha[N - 1]);
	for (int i = N - 1; i >= 0; i--) {
		y[i] = alpha[i] * y[i + 1] + beta[i];
	}
}

