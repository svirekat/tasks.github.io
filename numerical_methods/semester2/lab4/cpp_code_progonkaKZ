void runPythonScript(
	const string& scriptName,
	const string& file,
	int exNumber)
{
	string ex_str = to_string(exNumber);

#ifdef _WIN32
	string command = "python " + scriptName + " \"" + file + "\" " + ex_str;
#elif __linux__
	string command = "python3 " + scriptName + " \"" + file + "\" " + ex_str;
#endif

	int result = system(command.c_str());
	if (result != 0)
		cerr << "Ошибка при выполнении Python скрипта!\nКод ошибки: " << result << endl;
	else
		cout << "Графики успешно построены!" << endl;
}

